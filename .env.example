# Example configuration — copy to `.env` and fill in real values.
# Never commit `.env` (it is in .gitignore).

# ── Google GenAI authentication ────────────────────────────────────────
# Use ONE of the two modes below.

# Mode A: simple API key (AI Studio / Gemini API).
GOOGLE_API_KEY=

# Mode B: Vertex AI on GCP. Set USE_VERTEX=1 to enable.
USE_VERTEX=0
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# When using Vertex, also set GOOGLE_APPLICATION_CREDENTIALS to a service
# account JSON path, OR run `gcloud auth application-default login`.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ── Model identifiers (override only if you know what you're doing) ────
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
VEO_VIDEO_MODEL=veo-3.0-generate-001

# ── Server-side media storage ──────────────────────────────────────────
# Generated/uploaded assets are written here and served at /media/*.
MEDIA_DIR=./generated

# ── Azure OpenAI (optional second image provider: gpt-image-1) ─────────
# Leave blank to disable the "gpt_image" option in the sidebar.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# Name of the gpt-image-1 deployment in your Azure OpenAI resource.
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1
AZURE_OPENAI_API_VERSION=2025-04-01-preview
